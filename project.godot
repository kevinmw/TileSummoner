; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="TileSummoner"
run/main_scene="res://Scenes/main_menu.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"
config/screen_orientation=0
run/window_initial_position_type=0
run/window_initial_size=Vector2(1280, 720)

[autoload]

MessageServer="*res://Scripts/message/message_server.gd"
tileDatabase="*res://Scripts/tile/tile_database.gd"
TileConstants="*res://Scripts/tile/tile_constants.gd"
tileInventory="*res://Scripts/inventory/tile_inventory.gd"
PhantomCameraManager="*uid://duq6jhf6unyis"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080

[editor_plugins]

enabled=PackedStringArray("res://addons/gdUnit4/plugin.cfg", "res://addons/phantom_camera/plugin.cfg")

[gdunit4]

ui/toolbar/run_overall=true

[rendering]

viewport/hdr_2d=true
